
" Plugins, syntax, and colors
" ---------------------------------------------------------------------------
" vim-plug
" https://github.com/junegunn/vim-plug
" Specify a directory for plugins
" - For Neovim: ~/.local/share/nvim/plugged
" - Avoid using standard Vim directory names like 'plugin'

" Install vim-plug if we don't already have it
"---- vim-plug setup  ----
if has('nvim')
  let vimplug_exists = expand('~/.config/nvim/autoload/plug.vim')
  let plug_home = '~/.local/share/nvim/plugged'
else
  let vimplug_exists = expand('~/.vim/autoload/plug.vim')
  let plug_home = '~/.vim/plugged'
endif

if has('win32') && !has('win64')
  let curl_exists = expand('C:\Windows\Sysnative\curl.exe')
else
  let curl_exists = 'curl'
endif

if !filereadable(vimplug_exists)
  if !executable(curl_exists)
    echoerr "Please install curl or install vim-plug manually first."
    finish
  endif
  silent execute '!' . curl_exists . ' -fLo ' . shellescape(vimplug_exists) . ' --create-dirs https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim'
  augroup user_plug_bootstrap
    autocmd!
    autocmd VimEnter * PlugInstall --sync | qa
  augroup END
endif
"-------- end vim-plug setup ----

call plug#begin(plug_home)
" After adding new plugins you need to call :PlugInstall
Plug 'joshdick/onedark.vim'
Plug 'junegunn/fzf', { 'do': { -> fzf#install() } }
Plug 'junegunn/fzf.vim'
Plug 'itchyny/lightline.vim'
Plug 'tpope/vim-commentary'
Plug 'tpope/vim-surround'
Plug 'mg979/vim-visual-multi', {'branch': 'master'}
Plug 'tpope/vim-vinegar'

if has('nvim')
  Plug 'APZelos/blamer.nvim'
endif

Plug 'fenetikm/falcon'
Plug 'macguirerintoul/night_owl_light.vim'
Plug 'dense-analysis/ale'
Plug 'maximbaz/lightline-ale'
Plug 'sbdchd/neoformat'
Plug 'OmniSharp/omnisharp-vim'
call plug#end()
